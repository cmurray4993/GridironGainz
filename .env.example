# Public browser configuration. Copy this file to .env.local and replace the
# placeholders. Never put a service-role key, wallet seed phrase, or private key here.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_KEY

# Closed beta is intentionally devnet-only.
VITE_SOLANA_NETWORK=devnet
VITE_SOLANA_RPC=https://api.devnet.solana.com
VITE_TREASURY_WALLET=YOUR_DEDICATED_DEVNET_TREASURY_ADDRESS

# These remain false. They document completed external reviews; changing them
# does not replace legal, tax, or security approval.
VITE_ENABLE_MAINNET_COMMERCE=false
VITE_LEGAL_REVIEW_COMPLETE=false
VITE_TAX_REVIEW_COMPLETE=false
VITE_SECURITY_REVIEW_COMPLETE=false
